{
	"name": "macbook-landing",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "npm run lint:eslint && npm run lint:stylelint && npm run lint:prettier",
		"lint:eslint": "eslint .",
		"lint:eslint:fix": "eslint . --fix",
		"lint:stylelint": "stylelint \"src/**/*.{css,scss,sass}\"",
		"lint:stylelint:fix": "stylelint \"src/**/*.{css,scss,sass}\" --fix",
		"lint:prettier": "prettier . --check",
		"format": "prettier . --write",
		"prepare": "husky"
	},
	"dependencies": {
		"@gsap/react": "^2.1.2",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.6.1",
		"gsap": "^3.15.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-responsive": "^10.0.1",
		"three": "^0.184.0",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@eslint/js": "^10.0.1",
		"@rolldown/plugin-babel": "^0.2.3",
		"@types/babel__core": "^7.20.5",
		"@types/node": "^24.12.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jiti": "^2.7.0",
		"lint-staged": "^17.0.7",
		"meow": "^14.1.0",
		"postcss-scss": "^4.0.9",
		"prettier": "^3.8.4",
		"sass": "^1.101.0",
		"stylelint": "^17.13.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-prettier": "^5.0.3",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.12",
		"vite-plugin-checker": "^0.14.1"
	},
	"lint-staged": {
		"*.{js,cjs,mjs,ts,cts,mts,vue}": [
			"eslint --fix"
		],
		"*.{css,scss,sass}": [
			"stylelint --fix",
			"prettier --write"
		],
		"*.{html,json,md,yml,yaml}": [
			"prettier --write"
		]
	}
}
